    "@fastify/cors": "^9.0.0",
    "@fastify/rate-limit": "^9.1.0",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "tsx": "^4.19.0",
    "tsup": "^8.3.0",
    "typescript": "^5.6.0"
  }
}
